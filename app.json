{
  "expo": {
    "name": "crie-um-aplicativo-m",
    "slug": "crie-um-aplicativo-m",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-afq.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon-afq.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.todanoite.baby",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Precisamos acessar suas fotos para atualizar sua imagem de perfil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-afq.png",
        "backgroundColor": "#000000"
      },
      "package": "com.todanoite.baby",
      "versionCode": 2,
      "edgeToEdgeEnabled": false,
      "userInterfaceStyle": "automatic",
      "permissions": [
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "scheme": "crie-um-aplicativo-m",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://wge47dvbdvqm7g2vmsdnz45beh8s73xx.app.specular.dev"
    }
  }
}